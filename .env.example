# Plantilla de variables de entorno de la Herramienta de Activos Fijos.
# Copia este archivo como ".env" (junto al .exe o en la raíz en desarrollo) y
# rellena los valores reales. El ".env" NO se sube al repo (ver .gitignore).
#
# Las variables del sistema operativo tienen prioridad sobre las del .env.

# PAT de GitHub para que el AutoUpdater lea releases del repositorio PRIVADO.
# Usa un token de mínimo alcance (solo lectura de este repo). Es la MISMA
# variable que usan las demás herramientas Quetzaltic en la máquina.
QUETZALTIC_GITHUB_PAT=

# Microservicios (opcional; también se pueden fijar desde Configuración ⚙):
#   URL base de la API (sin '/' final).
QUETZALTIC_API_BASE_URL=
#   Token Bearer para autenticar con la API.
QUETZALTIC_API_TOKEN=
